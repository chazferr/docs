              "products/pre-trade-intelligence"
            ]
          },
          {
            "group": "Execution",
            "pages": [
              "products/cross-chain-execution",
              "products/perpetual-futures",
              "products/prediction-markets"
            ]
          },
          {
            "group": "Fees",
            "pages": [
              "products/fees"
            ]
          },
          {
            "group": "Roadmap",
            "pages": [
              "roadmap/overview",
              "roadmap/mobile-app"
            ]
          }
        ]
      },
      {
        "tab": "API Reference",
        "groups": [
          {
            "group": "API Documentation",
